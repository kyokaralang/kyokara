from collections import List, MutableList

type ParseResult = {
  grid: List<String>,
  w: Int,
  h: Int,
  start: Int,
  goal: Int,
  portal_type: List<Int>,
  portal_dest: List<Int>,
  portal_outer: List<Int>,
}
fn make_list(n: Int, value: Int) -> List<Int> {
  let out = MutableList.new()
  var i = 0
  while (i < n) {
    let _o = out.push(value)
    i = i + 1
  }
  out.to_list()
}

fn pad_right(text: String, width: Int) -> String {
  let out = MutableList.new().push(text)
  while (out[0].len() < width) {
    let _o = out.set(0, out[0].concat(" "))
  }
  out[0]
}

fn char_at(grid: List<String>, x: Int, y: Int) -> String {
  if (y < 0 || y >= grid.len()) {
    " "
  } else {
    let row = grid[y]
    if (x < 0 || x >= row.len()) {
      " "
    } else {
      row.substring(x, x + 1)
    }
  }
}

fn is_upper(ch: String) -> Bool {
  let code = ch.chars().to_list().get(0).unwrap_or(' ').code()
  code >= 'A'.code() && code <= 'Z'.code()
}

fn find_label(labels: MutableList<String>, label: String) -> Int {
  var i = 0
  while (i < labels.len()) {
    if (labels[i] == label) {
      return i
    }
    i = i + 1
  }
  -1
}

fn parse(input: String) -> ParseResult {
  let raw = input.lines().to_list()
  let h = raw.len()
  var w = 0
  for (line in raw) {
    if (line.len() > w) {
      w = line.len()
    }
  }

  let grid = MutableList.new()
  for (line in raw) {
    let _g = grid.push(pad_right(line, w))
  }

  let label_names = MutableList.new()
  let lx1 = MutableList.new()
  let ly1 = MutableList.new()
  let lx2 = MutableList.new()
  let ly2 = MutableList.new()
  let lc = MutableList.new()

  let portal_type = MutableList.from_list(make_list(w * h, 0))
  let portal_dest = MutableList.from_list(make_list(w * h, -1))
  let portal_outer = MutableList.from_list(make_list(w * h, 0))

  var start = -1
  var goal = -1
  for (y in 0 ..< h) {
    for (x in 0 ..< w) {
      let c = char_at(grid.to_list(), x, y)
      if (is_upper(c)) {
        if (is_upper(char_at(grid.to_list(), x + 1, y)) && !is_upper(char_at(grid.to_list(), x - 1, y))) {
          let label = c.concat(char_at(grid.to_list(), x + 1, y))
          var px = -1
          var py = -1
          if (char_at(grid.to_list(), x - 1, y) == ".") {
            px = x - 1
            py = y
          } else if (char_at(grid.to_list(), x + 2, y) == ".") {
            px = x + 2
            py = y
          }
          if (px >= 0) {
            let id = py * w + px
            let outer = if ((px <= 2 || py <= 2) || (px >= w - 3 || py >= h - 3)) { 1 } else { 0 }
            let _o = portal_outer.set(id, outer)
          }
        }

        if (is_upper(char_at(grid.to_list(), x, y + 1)) && !is_upper(char_at(grid.to_list(), x, y - 1))) {
          let label = c.concat(char_at(grid.to_list(), x, y + 1))
          var px = -1
          var py = -1
          if (char_at(grid.to_list(), x, y - 1) == ".") {
            px = x
            py = y - 1
          } else if (char_at(grid.to_list(), x, y + 2) == ".") {
            px = x
            py = y + 2
          }
          if (px >= 0) {
            let id = py * w + px
            let outer = if ((px <= 2 || py <= 2) || (px >= w - 3 || py >= h - 3)) { 1 } else { 0 }
            let _o = portal_outer.set(id, outer)
            if (label == "AA") {
              start = id
              let _t = portal_type.set(id, 2)
            } else if (label == "ZZ") {
              goal = id
              let _t = portal_type.set(id, 3)
            } else {
              let li = find_label(label_names, label)
              if (li == -1) {
                let _n = label_names.push(label)
                let _x1 = lx1.push(px)
                let _y1 = ly1.push(py)
                let _x2 = lx2.push(-1)
                let _y2 = ly2.push(-1)
                let _c = lc.push(1)
              } else if (lc[li] == 1) {
                let _x2 = lx2.set(li, px)
                let _y2 = ly2.set(li, py)
                let _c = lc.set(li, 2)
              }
            }
          }
        }
      }
    }
  }

  for (i in 0 ..< label_names.len()) {
    if (lc[i] == 2) {
      let a = ly1[i] * w + lx1[i]
      let b = ly2[i] * w + lx2[i]
      let _ta = portal_type.set(a, 1)
      let _tb = portal_type.set(b, 1)
      let _da = portal_dest.set(a, b)
      let _db = portal_dest.set(b, a)
    }
  }

  ParseResult {
    grid: grid.to_list(),
    w: w,
    h: h,
    start: start,
    goal: goal,
    portal_type: portal_type.to_list(),
    portal_dest: portal_dest.to_list(),
    portal_outer: portal_outer.to_list(),
  }
}

fn is_open(grid: List<String>, w: Int, h: Int, id: Int) -> Bool {
  if (id < 0 || id >= w * h) {
    return false
  }
  let x = id % w
  let y = id / w
  y >= 0 && y < h && char_at(grid, x, y) == "."
}

fn ensure_level(levels: MutableList<MutableList<Int>>, z: Int, size: Int) -> Unit {
  while (levels.len() <= z) {
    let _l = levels.push(MutableList.from_list(make_list(size, 0)))
  }
}

fn main() -> Int {
  let input = "AA.\n..B\nZZ."
  let parsed = parse(input)
  parsed.portal_outer.len() + parsed.portal_type.len() + parsed.portal_dest.len() + parsed.grid.len()
}
