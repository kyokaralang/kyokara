import collections

fn mix(i: Int) -> Int {
  let a = ((i << 3) | (i >> 2)) & 255
  let b = ((a ^ (i & 63)) << 1) & 511
  (b | (a >> 1)) ^ (i & 31)
}

fn main() -> Int {
  let acc = collections.MutableList.new().push(0)
  for (i in 0..<4096) {
    let value = mix(i)
    acc.set(0, (acc[0] + value) & 65535)
  }
  acc[0]
}
