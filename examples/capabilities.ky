import io

effect Audit

fn log(msg: String) -> String with Audit {
  io.println(msg)
  msg
}

fn copy_label(src: String, dst: String) -> String with Audit {
  log("Copied ".concat(src.concat(" to ".concat(dst))))
}

fn pure_transform(x: Int) -> Int {
  x * 2 + 1
}

fn main() -> Unit with Audit {
  io.println(copy_label("source.txt", "dest.txt"))
  io.println(pure_transform(20).to_string())
}
