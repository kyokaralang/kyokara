import io

fn greet(first: String, last: String) -> String {
  "Hello, ".concat(first.concat(" ".concat(last)))
}

fn repeat(s: String, n: Int) -> String {
  if n <= 0 {
    ""
  } else {
    s.concat(repeat(s, n - 1))
  }
}

fn main() -> Unit {
  io.println(greet("Ada", "Lovelace"))
  io.println(repeat("ha", 5))
}
