import io

fn factorial(n: Int) -> Int {
  if n <= 1 {
    1
  } else {
    n * factorial(n - 1)
  }
}

fn fibonacci(n: Int) -> Int {
  if n <= 0 {
    0
  } else {
    if n == 1 {
      1
    } else {
      fibonacci(n - 1) + fibonacci(n - 2)
    }
  }
}

fn main() -> Unit {
  io.println("factorial(10) = ".concat(factorial(10).to_string()))
  io.println("fibonacci(10) = ".concat(fibonacci(10).to_string()))
}
