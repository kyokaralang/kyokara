fn add(x: Int, y: Int) -> Int { x + y }

fn mul(x: Int, y: Int) -> Int { x * y }

fn precedence() -> Int {
  2 + 3 * 4
}

fn negate(x: Int) -> Int { -x }

fn main() -> Unit {
  println(int_to_string(add(10, 20)))
  println(int_to_string(mul(6, 7)))
  println(int_to_string(precedence()))
  println(int_to_string(negate(42)))
}
