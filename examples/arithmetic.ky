import io

fn add(x: Int, y: Int) -> Int { x + y }

fn mul(x: Int, y: Int) -> Int { x * y }

fn precedence() -> Int {
  2 + 3 * 4
}

fn negate(x: Int) -> Int { -x }

fn main() -> Unit {
  io.println(add(10, 20).to_string())
  io.println(mul(6, 7).to_string())
  io.println(precedence().to_string())
  io.println(negate(42).to_string())
}
