import io

type Point = { x: Int, y: Int }

fn distance_sq(p: Point) -> Int {
  p.x * p.x + p.y * p.y
}

fn main() -> Unit {
  let origin = Point { x: 0, y: 0 }
  let p = Point { x: 3, y: 4 }
  io.println("origin dist_sq: ".concat(distance_sq(origin).to_string()))
  io.println("p dist_sq: ".concat(distance_sq(p).to_string()))
}
