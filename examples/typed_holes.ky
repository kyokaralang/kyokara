type Direction = North | South | East | West

fn opposite(d: Direction) -> Direction {
  match (d) {
    Direction.North => Direction.South
    Direction.South => Direction.North
    Direction.East => _
    Direction.West => _
  }
}

fn todo_fn(x: Int, y: String) -> Bool {
  _
}

fn main() -> Direction {
  opposite(Direction.East)
}
